# Plantilla para .env local (NO commitear .env real)
# Copia a .env y llena con tus valores para Postgres local (Docker/pgAdmin/localhost)

# Para Postgres local
PGHOST=localhost
PGPORT=5432
PGDATABASE=inventariox
PGUSER=postgres
PGPASSWORD=tu_password_aqui

# O usa DATABASE_URL completa (ej Render local test)
# DATABASE_URL=postgresql://user:pass@localhost:5432/inventariox?sslmode=disable

# Render ignora estos y usa DATABASE_URL del dashboard
PGSSL=false

# Otras vars app (agregar si necesitas)
PORT=3000
SESSION_SECRET=tu_secret_aqui

