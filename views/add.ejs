<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Agregar Producto</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .container { background: white; padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); max-width: 500px; width: 100%; }
        h1 { color: #333; text-align: center; margin-bottom: 30px; font-weight: 300; }
        h1 i { margin-right: 10px; color: #28a745; }
        form { display: flex; flex-direction: column; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 5px; color: #495057; font-weight: 500; }
        input, textarea { width: 100%; padding: 12px; border: 2px solid #e9ecef; border-radius: 8px; font-size: 1em; transition: border-color 0.3s; box-sizing: border-box; }
        input:focus, textarea:focus { outline: none; border-color: #007bff; box-shadow: 0 0 0 3px rgba(0,123,255,0.1); }
        textarea { resize: vertical; min-height: 80px; }
        .btn { padding: 12px 24px; border: none; border-radius: 8px; cursor: pointer; font-size: 1em; transition: all 0.3s; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { background: #28a745; color: white; }
        .btn-primary:hover { background: #218838; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.2); }
        .btn-secondary { background: #6c757d; color: white; text-decoration: none; margin-top: 20px; align-self: flex-start; }
        .btn-secondary:hover { background: #5a6268; transform: translateY(-2px); }
    </style>
</head>
<body>
    <div class="container">
        <div style="text-align: right; margin-bottom: 20px;">
            <p style="margin: 0; color: #666;">Usuario: <strong><%= typeof user !== 'undefined' ? user.username : 'Usuario' %></strong> (<%= typeof user !== 'undefined' ? user.role : 'Rol' %>)</p>
        </div>
        <h1><i class="fas fa-plus-circle"></i> Agregar Producto</h1>
        <form action="/products" method="POST" onsubmit="return confirmSubmit()">
            <div class="form-group">
                <label for="name"><i class="fas fa-tag"></i> Nombre:</label>
                <input type="text" id="name" name="name" required>
            </div>
            <div class="form-group">
                <label for="description"><i class="fas fa-align-left"></i> Descripción:</label>
                <textarea id="description" name="description"></textarea>
            </div>
            <div class="form-group">
                <label for="price"><i class="fas fa-dollar-sign"></i> Precio:</label>
                <input type="number" id="price" step="0.01" name="price" required>
            </div>
            <div class="form-group">
                <label for="stock"><i class="fas fa-cubes"></i> Stock:</label>
                <input type="number" id="stock" name="stock" required>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Agregar Producto</button>
        </form>
        <a href="<%= user.role === 'admin' ? '/admin/products' : '/catalog' %>" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Volver</a>
    </div>
    <script>
        function confirmSubmit() {
            const name = document.getElementById('name').value.trim();
            if (!name) {
                alert('Ingrese el nombre del producto antes de continuar.');
                return false;
            }
            return confirm(`¿Estás seguro de crear el producto "${name}"?`);
        }
    </script>
</body>
</html>

