<div class="header">
    <h1><i class="fas <%= icon %>"></i> <%= title %></h1>
    <div class="user-section">
        <% if (typeof backHref !== 'undefined' && backHref) { %>
            <a href="<%= backHref %>" class="<%= typeof backClass !== 'undefined' && backClass ? backClass : 'back-btn' %>"><i class="fas <%= typeof backIcon !== 'undefined' && backIcon ? backIcon : 'fa-arrow-left' %>"></i> <%= typeof backLabel !== 'undefined' && backLabel ? backLabel : 'Volver' %></a>
        <% } %>
        <% if (typeof showCart !== 'undefined' && showCart) { %>
            <a href="/cart" class="cart-btn"><i class="fas fa-shopping-cart"></i> Carrito</a>
        <% } %>
        <div class="user-info">
            <p>Bienvenido</p>
            <p style="font-weight: bold; color: #667eea;"><%= user.username %></p>
            <span class="user-role">
                <% if (user.role === 'seller') { %>
                    <i class="fas fa-store"></i> Vendedor
                <% } else if (user.role === 'admin') { %>
                    <i class="fas fa-shield-alt"></i> Administrador
                <% } else { %>
                    <i class="fas fa-user"></i> Cliente
                <% } %>
            </span>
        </div>
        <form action="/logout" method="POST" style="margin: 0;">
            <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Cerrar Sesión</button>
        </form>
    </div>
</div>
