<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>InventarioX - Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
        .container { max-width: 1200px; margin: 0 auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        h1 { color: #333; margin: 0; }
        .user-info { text-align: right; }
        .user-info p { margin: 5px 0; color: #666; }
        .user-name { font-weight: bold; color: #007bff; }
        .user-role { background: #e7f3ff; color: #0056b3; padding: 5px 12px; border-radius: 20px; display: inline-block; font-size: 0.9em; }
        .logout-btn { background: #dc3545; color: white; padding: 8px 16px; border: none; border-radius: 5px; cursor: pointer; margin-top: 10px; }
        .logout-btn:hover { background: #c82333; }

        /* Admin Dashboard */
        .admin-dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .card { background: #f8f9fa; padding: 20px; border-radius: 8px; text-align: center; border-left: 4px solid #007bff; }
        .card i { font-size: 2em; color: #007bff; margin-bottom: 10px; }
        .card h3 { margin: 10px 0; color: #333; }
        .card p { color: #666; margin: 0; }

        /* Table styles */
        table { width: 100%; border-collapse: collapse; margin-top: 20px; border-radius: 8px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; color: #495057; font-weight: 600; text-transform: uppercase; font-size: 0.9em; }
        tr:hover { background: #f8f9fa; }
        .actions { display: flex; gap: 10px; }
        .btn { padding: 8px 12px; border: none; border-radius: 5px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; font-size: 0.9em; transition: all 0.3s; }
        .btn-primary { background: #28a745; color: white; }
        .btn-primary:hover { background: #218838; }
        .btn-edit { background: #007bff; color: white; }
        .btn-edit:hover { background: #0056b3; }
        .btn-delete { background: #dc3545; color: white; }
        .btn-delete:hover { background: #c82333; }

        /* Client View */
        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 20px; }
        .product-card { background: #f8f9fa; padding: 20px; border-radius: 8px; border: 1px solid #e9ecef; transition: all 0.3s; }
        .product-card:hover { box-shadow: 0 5px 15px rgba(0,0,0,0.1); transform: translateY(-5px); }
        .product-name { font-size: 1.2em; font-weight: bold; color: #333; margin: 10px 0; }
        .product-price { font-size: 1.5em; color: #28a745; font-weight: bold; margin: 10px 0; }
        .product-stock { color: #666; margin: 5px 0; }
        .stock-badge { display: inline-block; padding: 5px 10px; border-radius: 20px; font-size: 0.85em; margin-top: 10px; }
        .stock-available { background: #d4edda; color: #155724; }
        .stock-low { background: #fff3cd; color: #856404; }
        .stock-out { background: #f8d7da; color: #721c24; }

        /* Seller View */
        .seller-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .add-button { background: #28a745; color: white; padding: 12px 24px; border: none; border-radius: 8px; text-decoration: none; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
        .add-button:hover { background: #218838; }

        .section-title { color: #333; margin-top: 30px; margin-bottom: 15px; border-bottom: 2px solid #007bff; padding-bottom: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div>
                <h1><i class="fas fa-boxes"></i> InventarioX</h1>
            </div>
            <div class="user-info">
                <p>Bienvenido</p>
                <p class="user-name"><%= typeof user !== 'undefined' ? user.username : 'Usuario' %></p>
                <span class="user-role">
                    <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
                        <i class="fas fa-shield-alt"></i> Administrador
                    <% } else if (typeof user !== 'undefined' && user.role === 'seller') { %>
                        <i class="fas fa-store"></i> Vendedor
                    <% } else { %>
                        <i class="fas fa-user"></i> Cliente
                    <% } %>
                </span>
                <form action="/logout" method="POST" style="margin: 0;">
                    <button type="submit" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Cerrar Sesión</button>
                </form>
            </div>
        </div>

        <!-- ADMIN DASHBOARD -->
        <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
            <div class="admin-dashboard">
                <div class="card">
                    <i class="fas fa-box"></i>
                    <h3><%= products.length %></h3>
                    <p>Productos Total</p>
                </div>
                <div class="card">
                    <i class="fas fa-cubes"></i>
                    <h3><%= products.reduce((sum, p) => sum + p.stock, 0) %></h3>
                    <p>Unidades en Stock</p>
                </div>
                <div class="card">
                    <i class="fas fa-dollar-sign"></i>
                    <h3>$<%= products.reduce((sum, p) => sum + (p.price * p.stock), 0).toFixed(2) %></h3>
                    <p>Valor Total</p>
                </div>
            </div>

            <div class="seller-header">
                <h2 class="section-title"><i class="fas fa-list"></i> Gestión de Productos</h2>
                <a href="/add" class="add-button"><i class="fas fa-plus"></i> Nuevo Producto</a>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Valor Total</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                        <tr>
                            <td><%= product.id %></td>
                            <td><strong><%= product.name %></strong></td>
                            <td><%= product.description %></td>
                            <td><i class="fas fa-dollar-sign"></i> <%= product.price %></td>
                            <td><%= product.stock %></td>
                            <td><%= (product.price * product.stock).toFixed(2) %></td>
                            <td class="actions">
                                <a href="/edit/<%= product.id %>" class="btn btn-edit"><i class="fas fa-edit"></i> Editar</a>
                                <a href="#" onclick="deleteProduct(<%= product.id %>)" class="btn btn-delete"><i class="fas fa-trash"></i> Eliminar</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

        <!-- SELLER DASHBOARD -->
        <% } else if (typeof user !== 'undefined' && user.role === 'seller') { %>
            <h2 class="section-title"><i class="fas fa-store"></i> Panel de Vendedor</h2>
            <div class="seller-header">
                <p style="margin: 0;">Gestiona tus productos y stock</p>
                <a href="/add" class="add-button"><i class="fas fa-plus"></i> Agregar Producto</a>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(product => { %>
                        <tr>
                            <td><%= product.id %></td>
                            <td><strong><%= product.name %></strong></td>
                            <td><%= product.description %></td>
                            <td><i class="fas fa-dollar-sign"></i> <%= product.price %></td>
                            <td><%= product.stock %></td>
                            <td class="actions">
                                <a href="/edit/<%= product.id %>" class="btn btn-edit"><i class="fas fa-edit"></i> Editar</a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

        <!-- CLIENT DASHBOARD -->
        <% } else { %>
            <h2 class="section-title"><i class="fas fa-shopping-bag"></i> Catálogo de Productos</h2>
            <div class="product-grid">
                <% products.forEach(product => { %>
                    <div class="product-card">
                        <h3 class="product-name"><%= product.name %></h3>
                        <p style="color: #999; margin: 5px 0;"><%= product.description %></p>
                        <div class="product-price"><i class="fas fa-dollar-sign"></i><%= product.price %></div>
                        <div class="product-stock">
                            <i class="fas fa-cubes"></i> Stock: <%= product.stock %>
                            <% if (product.stock > 10) { %>
                                <span class="stock-badge stock-available"><i class="fas fa-check-circle"></i> Disponible</span>
                            <% } else if (product.stock > 0) { %>
                                <span class="stock-badge stock-low"><i class="fas fa-exclamation-triangle"></i> Bajo Stock</span>
                            <% } else { %>
                                <span class="stock-badge stock-out"><i class="fas fa-times-circle"></i> Agotado</span>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <script>
        function deleteProduct(id) {
            if (confirm('¿Estás seguro de que quieres eliminar este producto?')) {
                fetch(`/products/${id}`, { method: 'DELETE' })
                    .then(() => location.reload());
            }
        }
    </script>
</body>
</html>