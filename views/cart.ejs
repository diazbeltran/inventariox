<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Carrito - InventarioX</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; background: linear-gradient(135deg, #154c79 0%, #1f6aa5 100%); min-height: 100vh; }
        .container { max-width: 1200px; margin: 0 auto; }
        .cart-items, .cart-total, .empty-cart { background: white; border-radius: 16px; padding: 20px; box-shadow: 0 15px 30px rgba(10,24,39,0.15); }
        .cart-items { margin-bottom: 20px; }
        .cart-item { display: flex; justify-content: space-between; align-items: center; padding: 15px 0; border-bottom: 1px solid #eef2f5; gap: 16px; }
        .cart-item:last-child { border-bottom: none; }
        .item-info { display: flex; align-items: center; gap: 15px; min-width: 0; }
        .item-image { width: 60px; height: 60px; background: linear-gradient(135deg, #123b5d 0%, #1f6aa5 100%); display: flex; align-items: center; justify-content: center; color: white; border-radius: 12px; }
        .item-details h3 { margin: 0; color: #243240; }
        .item-details p { margin: 5px 0; color: #6b7c8b; }
        .item-quantity { display: flex; align-items: center; gap: 10px; }
        .quantity-btn, .remove-btn, .checkout-btn { border: none; cursor: pointer; }
        .quantity-btn { background: #1f6aa5; color: white; padding: 5px 10px; border-radius: 6px; }
        .remove-btn { background: #dc3545; color: white; padding: 8px 10px; border-radius: 8px; }
        .item-price { font-weight: bold; color: #13653c; min-width: 90px; text-align: right; }
        .cart-total { text-align: right; }
        .total-amount { font-size: 1.6em; font-weight: bold; color: #13653c; margin: 10px 0; }
        .checkout-btn { background: #13653c; color: white; padding: 14px 26px; border-radius: 10px; font-size: 1em; }
        .empty-cart { text-align: center; }
        .empty-cart i { font-size: 4em; color: #c3cfda; }
        .empty-cart h2 { color: #6b7c8b; margin: 10px 0; }
        @media (max-width: 720px) {
            .cart-item { flex-direction: column; align-items: flex-start; }
            .item-price { text-align: left; }
        }
    </style>
</head>
<body>
    <div class="container">
        <%- include('partials/shop-header', { title: 'Carrito de Compras', icon: 'fa-shopping-cart', backHref: '/catalog', backLabel: 'Volver al Catalogo', backClass: 'back-btn', user }) %>
        <% if (cart.length === 0) { %>
            <div class="empty-cart">
                <i class="fas fa-shopping-cart"></i>
                <h2>Tu carrito esta vacio</h2>
                <p>Agrega productos desde el catalogo.</p>
                <a href="/catalog" class="checkout-btn" style="text-decoration: none; display: inline-block; margin-top: 18px;">Ir al catalogo</a>
            </div>
        <% } else { %>
            <div class="cart-items">
                <% cart.forEach(item => { %>
                    <div class="cart-item">
                        <div class="item-info">
                            <div class="item-image"><i class="fas fa-box"></i></div>
                            <div class="item-details">
                                <h3><%= item.name %></h3>
                                <p><%= item.description || 'Sin descripcion' %></p>
                            </div>
                        </div>
                        <div class="item-quantity">
                            <button class="quantity-btn" onclick="updateQuantity(<%= item.id %>, <%= item.quantity - 1 %>)">-</button>
                            <span><%= item.quantity %></span>
                            <button class="quantity-btn" onclick="updateQuantity(<%= item.id %>, <%= item.quantity + 1 %>)">+</button>
                        </div>
                        <div class="item-price">$<%= (item.price * item.quantity).toFixed(2) %></div>
                        <button class="remove-btn" onclick="removeFromCart(<%= item.id %>)"><i class="fas fa-trash"></i></button>
                    </div>
                <% }); %>
            </div>
            <div class="cart-total">
                <h3>Total</h3>
                <div class="total-amount">$<%= total.toFixed(2) %></div>
                <button class="checkout-btn" onclick="checkout()"><i class="fas fa-credit-card"></i> Generar compra</button>
            </div>
        <% } %>
    </div>
    <script>
        async function handleResponse(response, successAction) {
            if (response.ok) {
                successAction();
                return;
            }

            const payload = await response.json().catch(() => ({}));
            alert(payload.error || 'No se pudo completar la accion');
        }

        function updateQuantity(productId, newQuantity) {
            if (newQuantity < 1) return;
            fetch('/cart/update/' + productId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ quantity: newQuantity }),
                credentials: 'include'
            })
            .then(response => handleResponse(response, () => location.reload()))
            .catch(() => alert('Error al actualizar cantidad'));
        }

        function removeFromCart(productId) {
            fetch('/cart/remove/' + productId, {
                method: 'POST',
                credentials: 'include'
            })
            .then(response => handleResponse(response, () => location.reload()))
            .catch(() => alert('Error al remover del carrito'));
        }

        function checkout() {
            if (!confirm('Seguro que quieres generar la compra?')) {
                return;
            }

            fetch('/cart/checkout', {
                method: 'POST',
                credentials: 'include'
            })
            .then(response => handleResponse(response, () => {
                alert('Compra generada exitosamente');
                location.href = '/catalog';
            }))
            .catch(() => alert('Error al generar la compra'));
        }
    </script>
</body>
</html>
