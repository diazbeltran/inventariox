<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Catalogo - InventarioX</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; background: linear-gradient(135deg, #154c79 0%, #1f6aa5 100%); min-height: 100vh; }
        .container { max-width: 1200px; margin: 0 auto; }
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .product-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 15px 30px rgba(10,24,39,0.15); transition: transform 0.25s; }
        .product-card:hover { transform: translateY(-6px); }
        .product-image { height: 180px; background: linear-gradient(135deg, #123b5d 0%, #1f6aa5 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 3em; }
        .product-info { padding: 20px; }
        .product-name { font-size: 1.2em; font-weight: bold; color: #22303d; margin: 10px 0; }
        .product-description { color: #738291; font-size: 0.95em; margin-bottom: 10px; }
        .product-price { font-size: 1.45em; color: #13653c; font-weight: bold; margin: 10px 0; }
        .stock-info { display: flex; justify-content: space-between; align-items: center; margin: 15px 0; padding-top: 15px; border-top: 1px solid #eef2f5; }
        .stock-badge { display: inline-block; padding: 5px 10px; border-radius: 20px; font-size: 0.85em; }
        .stock-available { background: #d4edda; color: #155724; }
        .stock-low { background: #fff3cd; color: #856404; }
        .stock-out { background: #f8d7da; color: #721c24; }
        .empty-state { background: white; padding: 60px 20px; text-align: center; border-radius: 16px; }
        .empty-state i { font-size: 4em; color: #c3cfda; }
        .empty-state h2 { color: #6c7b88; }
        .btn-add-cart { background: #1f6aa5; color: white; border: none; padding: 12px 15px; border-radius: 10px; cursor: pointer; margin-top: 12px; width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 5px; }
        .btn-add-cart:hover { background: #185685; }
        .discount-badge { background: #dc3545; color: white; padding: 2px 8px; border-radius: 999px; font-size: 0.8em; margin-left: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <%- include('partials/shop-header', { title: 'Catalogo de Productos', icon: 'fa-shopping-bag', showCart: true, user }) %>
        <% if (products.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-box-open"></i>
                <h2>No hay productos disponibles</h2>
                <p>Vuelve mas tarde para revisar el catalogo.</p>
            </div>
        <% } else { %>
            <div class="products-grid">
                <% products.forEach(product => { %>
                    <div class="product-card">
                        <div class="product-image"><i class="fas fa-box"></i></div>
                        <div class="product-info">
                            <h3 class="product-name"><%= product.name %></h3>
                            <p class="product-description"><%= product.description || 'Sin descripcion' %></p>
                            <% if (product.discount > 0) { %>
                                <div class="product-price">
                                    <span style="text-decoration: line-through; color: #8897a5;">$<%= product.originalPrice.toFixed(2) %></span>
                                    <span> $<%= product.price.toFixed(2) %></span>
                                    <span class="discount-badge"><%= product.discount %>% OFF</span>
                                </div>
                                <% if (product.offerDescription) { %>
                                    <p style="color: #1f6aa5; font-size: 0.92em;"><%= product.offerDescription %></p>
                                <% } %>
                            <% } else { %>
                                <div class="product-price">$<%= product.price.toFixed(2) %></div>
                            <% } %>
                            <div class="stock-info">
                                <span><i class="fas fa-cubes"></i> Disponible: <%= product.stock %></span>
                            </div>
                            <% if (product.stock > 10) { %>
                                <span class="stock-badge stock-available">Disponible</span>
                            <% } else if (product.stock > 0) { %>
                                <span class="stock-badge stock-low">Stock bajo</span>
                            <% } else { %>
                                <span class="stock-badge stock-out">Agotado</span>
                            <% } %>
                            <% if (product.stock > 0) { %>
                                <button onclick="addToCart(<%= product.id %>)" class="btn-add-cart"><i class="fas fa-cart-plus"></i> Agregar al carrito</button>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
    <script>
        function addToCart(productId) {
            fetch('/cart/add/' + productId, {
                method: 'POST',
                credentials: 'include'
            })
            .then(async response => {
                if (response.ok) {
                    alert('Producto agregado al carrito');
                    return;
                }

                const payload = await response.json().catch(() => ({}));
                alert(payload.error || 'Error al agregar al carrito');
            })
            .catch(() => {
                alert('Error al agregar al carrito');
            });
        }
    </script>
</body>
</html>
