<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - InventarioX</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f6fb; color: #243240; }
        .sidebar { position: fixed; left: 0; top: 0; width: 250px; height: 100vh; background: linear-gradient(180deg, #154c79 0%, #1f6aa5 100%); padding: 20px; color: white; overflow-y: auto; }
        .logo { font-size: 1.5em; font-weight: bold; margin-bottom: 30px; text-align: center; }
        .menu-item { padding: 12px 15px; margin: 5px 0; border-radius: 8px; text-decoration: none; color: white; display: block; }
        .menu-item:hover, .menu-item.active { background: rgba(255,255,255,0.15); }
        .main { margin-left: 250px; padding: 28px; }
        .header { background: white; border-radius: 18px; padding: 24px; margin-bottom: 24px; box-shadow: 0 10px 30px rgba(19,41,61,0.08); display: flex; justify-content: space-between; align-items: center; }
        .header p { color: #667788; margin-top: 8px; }
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 16px; margin-bottom: 24px; }
        .card { background: white; border-radius: 18px; padding: 22px; box-shadow: 0 10px 30px rgba(19,41,61,0.08); }
        .card i { color: #1f6aa5; font-size: 1.8em; margin-bottom: 10px; }
        .card .value { font-size: 1.9em; font-weight: 700; color: #154c79; }
        .card .label { color: #6b7c8b; margin-top: 8px; }
        .grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 20px; }
        .panel { background: white; border-radius: 18px; padding: 22px; box-shadow: 0 10px 30px rgba(19,41,61,0.08); }
        .panel h2 { margin-bottom: 14px; }
        .list { display: grid; gap: 10px; }
        .list-item { padding: 12px 14px; border-radius: 12px; background: #f7f9fc; border-left: 4px solid #1f6aa5; }
        .list-item.danger { border-left-color: #dc3545; }
        .actions { display: grid; gap: 14px; }
        .action-card { text-decoration: none; color: inherit; background: linear-gradient(135deg, #ecf5fb 0%, #ffffff 100%); padding: 20px; border-radius: 16px; border: 1px solid #dce8f2; }
        .action-card h3 { margin-bottom: 6px; }
        .action-card p { color: #617282; }
        .muted { color: #6b7c8b; }
        @media (max-width: 1050px) {
            .grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 720px) {
            .sidebar { position: static; width: 100%; height: auto; }
            .main { margin-left: 0; }
            .header { flex-direction: column; align-items: flex-start; gap: 12px; }
        }
    </style>
</head>
<body>
    <%- include('../partials/admin-sidebar', { section: 'dashboard' }) %>
    <div class="main">
        <div class="header">
            <div>
                <h1><i class="fas fa-chart-line"></i> Dashboard de Inventario</h1>
                <p>Resumen del nuevo modelo con bodegas, insumos y productos compuestos.</p>
            </div>
            <div>
                <strong><%= user.username %></strong><br>
                <span class="muted">Administrador</span>
            </div>
        </div>

        <div class="stats">
            <div class="card">
                <i class="fas fa-boxes-stacked"></i>
                <div class="value"><%= supplies.length %></div>
                <div class="label">Insumos registrados</div>
            </div>
            <div class="card">
                <i class="fas fa-box"></i>
                <div class="value"><%= products.length %></div>
                <div class="label">Productos vendibles</div>
            </div>
            <div class="card">
                <i class="fas fa-industry"></i>
                <div class="value"><%= recipeProducts %></div>
                <div class="label">Productos con receta</div>
            </div>
            <div class="card">
                <i class="fas fa-warehouse"></i>
                <div class="value"><%= warehouses.length %></div>
                <div class="label">Bodegas activas</div>
            </div>
            <div class="card">
                <i class="fas fa-dollar-sign"></i>
                <div class="value">$<%= totalValue.toFixed(2) %></div>
                <div class="label">Valor disponible para venta</div>
            </div>
            <div class="card">
                <i class="fas fa-cubes"></i>
                <div class="value"><%= totalStock %></div>
                <div class="label">Unidades disponibles</div>
            </div>
        </div>

        <div class="grid">
            <div class="panel">
                <h2>Alertas de disponibilidad</h2>
                <% const lowStockProducts = products.filter(product => product.stock > 0 && product.stock < 5); %>
                <% const outOfStockProducts = products.filter(product => product.stock === 0); %>
                <div class="list">
                    <% if (outOfStockProducts.length === 0 && lowStockProducts.length === 0) { %>
                        <div class="list-item">
                            <strong>Todo en orden</strong><br>
                            <span class="muted">No hay productos agotados ni con stock critico.</span>
                        </div>
                    <% } %>
                    <% outOfStockProducts.forEach(product => { %>
                        <div class="list-item danger">
                            <strong><%= product.name %></strong><br>
                            <span class="muted">Agotado. Revisa sus insumos o stock manual.</span>
                        </div>
                    <% }) %>
                    <% lowStockProducts.forEach(product => { %>
                        <div class="list-item">
                            <strong><%= product.name %></strong><br>
                            <span class="muted">Stock bajo: <%= product.stock %> unidades.</span>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="actions">
                <a href="/admin/products" class="action-card">
                    <h3><i class="fas fa-layer-group"></i> Gestionar Inventario</h3>
                    <p>Crea bodegas, categorias, insumos y productos con receta.</p>
                </a>
                <a href="/admin/offers" class="action-card">
                    <h3><i class="fas fa-tags"></i> Gestionar Ofertas</h3>
                    <p>Aplica promociones solo sobre productos vendibles.</p>
                </a>
                <a href="/admin/clients" class="action-card">
                    <h3><i class="fas fa-users"></i> Gestionar Proveedores</h3>
                    <p>Manten la informacion de clientes y proveedores del sistema.</p>
                </a>
                <div class="action-card">
                    <h3><i class="fas fa-circle-info"></i> Lectura del modelo</h3>
                    <p><%= recipeProducts %> productos usan receta y <%= manualProducts %> siguen en modo manual para una migracion gradual.</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
